{
  "name": "wow-bis",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "next dev -p 5123",
    "build": "next build",
    "start": "next start",
    "lint": "oxlint .",
    "test": "vitest",
    "test:unit": "vitest --project unit",
    "test:stories": "vitest --project \"storybook*\"",
    "test:coverage": "vitest --coverage",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "chromatic": "chromatic --exit-zero-on-changes",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "stylelint": "stylelint \"src/**/*.css\"",
    "typecheck": "tsc --noEmit",
    "perf:size": "size-limit",
    "perf:lighthouse": "CHROME_PATH=$(node -e \"process.stdout.write(require('playwright').chromium.executablePath())\") lhci autorun",
    "prepare": "lefthook install"
  },
  "dependencies": {
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.576.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "radix-ui": "^1.4.3",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@lhci/cli": "^0.15.1",
    "@size-limit/file": "^12.0.1",
    "@storybook/addon-docs": "^10.3.4",
    "@storybook/addon-themes": "^10.3.4",
    "@storybook/addon-vitest": "10.2.14",
    "@storybook/react": "^10.3.4",
    "@storybook/react-vite": "^10.3.4",
    "@tailwindcss/postcss": "^4.2.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "@vitest/browser": "^4.1.2",
    "@vitest/browser-playwright": "^4.1.2",
    "@vitest/coverage-v8": "^4.1.2",
    "babel-plugin-react-compiler": "1.0.0",
    "chromatic": "^15.3.1",
    "jsdom": "^28.1.0",
    "lefthook": "^2.1.4",
    "oxlint": "^1.58.0",
    "playwright": "^1.59.1",
    "size-limit": "^12.0.1",
    "storybook": "^10.3.4",
    "stylelint": "^17.6.0",
    "stylelint-config-standard": "^40.0.0",
    "tailwindcss": "^4.2.2",
    "tw-animate-css": "^1.4.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
